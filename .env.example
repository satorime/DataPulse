# Copy this file to .env and fill in your values
# .env is git-ignored — never commit it

# PostgreSQL
POSTGRES_DB=datapulse
POSTGRES_USER=datapulse
POSTGRES_PASSWORD=change_me

# JWT — must be the same in both services, min 32 characters
JWT_SECRET=change_me_to_a_long_random_string_32chars

# Django
DJANGO_SECRET_KEY=change_me_to_another_long_random_string
